function giveSword(p: player, id: number):: item:
    switch {_id}:
        case 1:
            set {_item} to sword(wooden sword, "Rotten Blade", 1)
        case 2:
            set {_item} to sword(diamond sword, "Frosted Fang", 2)
        case 3:
            set {_item} to sword(golden sword, "Molten Cutlass", 3)
        case 4:
            set {_item} to sword(stone sword, "Gravedigger's Edge", 4)
        case 5:
            set {_item} to sword(iron sword, "Shadow Saber", 5)
        case 6:
            set {_item} to sword(wooden sword, "Splintered Reaper", 6)
        case 7:
            set {_item} to sword(diamond sword, "Glacier Fang", 7)
        case 8:
            set {_item} to sword(golden sword, "Cinderblade", 8)
        case 9:
            set {_item} to sword(stone sword, "Bonecrusher", 9)
        case 10:
            set {_item} to sword(iron sword, "Rustbite Edge", 10)
        case 11:
            set {_item} to sword(wooden sword, "Timberfang", 11)
        case 12:
            set {_item} to sword(diamond sword, "Frostbite Saber", 12)
        case 13:
            set {_item} to sword(golden sword, "Blazing Cutlass", 13)
        case 14:
            set {_item} to sword(stone sword, "Tombstone Blade", 14)
        case 15:
            set {_item} to sword(iron sword, "Ironshank", 15)
        case 16:
            set {_item} to sword(wooden sword, "Withered Edge", 16)
        case 17:
            set {_item} to sword(diamond sword, "Crystal Fang", 17)
        case 18:
            set {_item} to sword(golden sword, "Emberfall Blade", 18)
        case 19:
            set {_item} to sword(stone sword, "Cairnbreaker", 19)
        case 20:
            set {_item} to sword(iron sword, "Steelclaw Saber", 20)
        case 21:
            set {_item} to sword(wooden sword, "Rotwood Blade", 21)
        case 22:
            set {_item} to sword(diamond sword, "Starlight Fang", 22)
        case 23:
            set {_item} to sword(golden sword, "Wildfire Saber", 23)
        case 24:
            set {_item} to sword(stone sword, "Gravebound Edge", 24)
        case 25:
            set {_item} to sword(iron sword, "Bloodiron Blade", 25)
        case 26:
            set {_item} to sword(wooden sword, "Driftwood Fang", 26)
        case 27:
            set {_item} to sword(diamond sword, "Icebound Saber", 27)
        case 28:
            set {_item} to sword(golden sword, "Ashfall Blade", 28)
        case 29:
            set {_item} to sword(stone sword, "Boneyard Edge", 29)
        case 30:
            set {_item} to sword(iron sword, "Warforged Saber", 30)
        default:
            send "&cInvalid weapon ID." to {_p}
            stop
    return {_item}

