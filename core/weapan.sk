        case 18:
            set {_item} to dagger(golden sword, "Emberfall Knife", 18)
        case 19:
            set {_item} to dagger(stone sword, "Cairnbreaker Shank", 19)
        case 20:
            set {_item} to dagger(iron sword, "Steelclaw Fang", 20)
        case 21:
            set {_item} to dagger(wooden sword, "Rotwood Shiv", 21)
        case 22:
            set {_item} to dagger(diamond sword, "Starlight Dirk", 22)
        case 23:
            set {_item} to dagger(golden sword, "Wildfire Knife", 23)
        case 24:
            set {_item} to dagger(stone sword, "Gravebound Shank", 24)
        case 25:
            set {_item} to dagger(iron sword, "Bloodiron Fang", 25)
        case 26:
            set {_item} to dagger(wooden sword, "Driftwood Shiv", 26)
        case 27:
            set {_item} to dagger(diamond sword, "Icebound Dirk", 27)
        case 28:
            set {_item} to dagger(golden sword, "Ashfall Knife", 28)
        case 29:
            set {_item} to dagger(stone sword, "Boneyard Shank", 29)
        case 30:
            set {_item} to dagger(iron sword, "Warforged Fang", 30)
        default:
            send "&cInvalid weapon ID." to {_p}
            stop
    return {_item}

command /givesword <number>:
    permission: admin.item
    trigger:
        set {_item} to giveSword(player, arg-1)
        give {_item} to player

command /giveaxe <number>:
    permission: admin.item
    trigger:
        set {_item} to giveAxe(player, arg-1)
        give {_item} to player

command /givedagger <number>:
    permission: admin.item
    trigger:
        set {_item} to giveDagger(player, arg-1)
        give {_item} to player