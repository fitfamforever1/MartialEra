function giveDagger(p: player, id: number):: item:
    switch {_id}:
        case 1:
            set {_item} to dagger(wooden sword, "Rotten Shiv", 1)
        case 2:
            set {_item} to dagger(diamond sword, "Frosted Dirk", 2)
        case 3:
            set {_item} to dagger(golden sword, "Molten Knife", 3)
        case 4:
            set {_item} to dagger(stone sword, "Gravedigger's Shank", 4)
