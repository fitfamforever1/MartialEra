            set {_item} to dagger(wooden sword, "Splintered Shiv", 6)
        case 7:
            set {_item} to dagger(diamond sword, "Glacier Dirk", 7)
        case 8:
            set {_item} to dagger(golden sword, "Cinderknife", 8)
        case 9:
            set {_item} to dagger(stone sword, "Bonecrusher Shank", 9)
        case 10:
            set {_item} to dagger(iron sword, "Rustbite Fang", 10)
