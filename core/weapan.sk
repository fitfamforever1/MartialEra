        case 14:
            set {_item} to dagger(stone sword, "Tombstone Shank", 14)
        case 15:
            set {_item} to dagger(iron sword, "Ironshank Fang", 15)
        case 16:
            set {_item} to dagger(wooden sword, "Withered Shiv", 16)
