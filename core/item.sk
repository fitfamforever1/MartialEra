function giveWeapon(p: player, id: number):
    switch {_id}:
        case 1:
            give sword(wooden sword, "Splintered Wooden Sword", 1) to {_p}
        case 2:
            give dagger(golden sword, "Golden Kitchen Knife", 1) to {_p}
        case 3:
            give axe(stone axe, "Chipped Stone Hatchet", 2) to {_p}
        case 4:
            give sword(stone sword, "Worn Stone Sword", 2) to {_p}
        case 5:
            give dagger(golden sword, "Golden Paring Knife", 3) to {_p}
