function giveArmor(p: player, setId: number):
    switch {_setId}:
        case 1:
            set {_item} to diamond helmet named "&fWanderer Helmet"
            set {_item} to helmet({_item}, 1)
            give {_item} to {_p}
            set {_item} to diamond chestplate named "&fWanderer Chestplate"
            set {_item} to chestplate({_item}, 1)
            give {_item} to {_p}
            set {_item} to diamond leggings named "&fWanderer Leggings"
            set {_item} to leggings({_item}, 1)
            give {_item} to {_p}
            set {_item} to diamond boots named "&fWanderer Boots"
            set {_item} to boots({_item}, 1)
            give {_item} to {_p}

command /givearmor <number>:
    permission: admin.item
    trigger:
        giveArmor(player, arg-1)
           
command /giveweapon <number>:
    permission: admin.item
    trigger:
        giveWeapon(player, arg-1)