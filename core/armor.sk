            set {_item} to chestplate(leather chestplate, "Starfall Chestplate", 22, 33, 0, 111)
        case 23:
            set {_item} to chestplate(leather chestplate, "Dragon Chestplate", 23, 32, 59, 73)
        case 24:
            set {_item} to chestplate(leather chestplate, "Fallen Chestplate", 24, 70, 70, 70)
        case 25:
            set {_item} to chestplate(leather chestplate, "Blood Chestplate", 25, 208, 36, 68)
        case 26:
            set {_item} to chestplate(leather chestplate, "Fairy Chestplate", 26, 78, 65, 189)
        case 27:
            set {_item} to chestplate(leather chestplate, "Divan Chestplate", 27, 42, 83, 166)
        case 28:
