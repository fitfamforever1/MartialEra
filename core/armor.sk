function giveChestplate(p: player, id: number):: item:
    switch {_id}:
        case 1:
            set {_item} to chestplate(leather chestplate, "Rotten Chestplate", 1, 121, 127, 68)
        case 2:
            set {_item} to chestplate(leather chestplate, "Frost Chestplate", 2, 113, 178, 201)
        case 3:
            set {_item} to chestplate(leather chestplate, "Molten Chestplate", 3, 35, 35, 39)
        case 4:
            set {_item} to chestplate(leather chestplate, "Gravedigger's Chestplate", 4, 63, 37, 43)
        case 5:
            set {_item} to chestplate(leather chestplate, "Shadow Chestplate", 5, 61, 61, 61)
