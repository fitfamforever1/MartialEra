        case 18:
            set {_item} to chestplate(leather chestplate, "Ember Chestplate", 18, 254, 231, 97)
        case 19:
            set {_item} to chestplate(leather chestplate, "Chaos Chestplate", 19, 212, 64, 76)
        case 20:
            set {_item} to chestplate(leather chestplate, "Golem Chestplate", 20, 149, 137, 118)
        case 21:
            set {_item} to chestplate(leather chestplate, "Divine Chestplate", 21, 235, 223, 243)
