        case 18:
            set {_item} to boots(leather boots, "Ember Boots", 18, 254, 231, 97)
        case 19:
            set {_item} to boots(leather boots, "Chaos Boots", 19, 212, 64, 76)
        case 20:
            set {_item} to boots(leather boots, "Golem Boots", 20, 149, 137, 118)
        case 21:
            set {_item} to boots(leather boots, "Divine Boots", 21, 235, 223, 243)
        case 22:
            set {_item} to boots(leather boots, "Starfall Boots", 22, 33, 0, 111)
        case 23:
            set {_item} to boots(leather boots, "Dragon Boots", 23, 32, 59, 73)
        case 24:
            set {_item} to boots(leather boots, "Fallen Boots", 24, 70, 70, 70)
        case 25:
            set {_item} to boots(leather boots, "Blood Boots", 25, 208, 36, 68)
        case 26:
            set {_item} to boots(leather boots, "Fairy Boots", 26, 78, 65, 189)
        case 27:
            set {_item} to boots(leather boots, "Divan Boots", 27, 42, 83, 166)
        case 28:
            set {_item} to boots(leather boots, "Ashfall Boots", 28, 72, 72, 71)
        case 29:
            set {_item} to boots(leather boots, "Bone Boots", 29, 171, 170, 201)
        case 30:
            set {_item} to boots(leather boots, "Warforged Boots", 30, 36, 36, 36)
        default:
            send "&cInvalid armor ID." to {_p}
            stop
    return {_item}

command /givehelmet <number>:
    permission: admin.item
    trigger:
        set {_item} to giveHelmet(player, arg-1)
        give {_item} to player

command /givechestplate <number>:
    permission: admin.item
    trigger:
        set {_item} to giveChestplate(player, arg-1)
        give {_item} to player

command /giveleggings <number>:
    permission: admin.item
    trigger:
        set {_item} to giveLeggings(player, arg-1)
        give {_item} to player

command /giveboots <number>:
    permission: admin.item
    trigger:
        set {_item} to giveBoots(player, arg-1)
        give {_item} to player

command /giveset <number>:
    permission: admin.item
    trigger:
        set {_item1} to giveHelmet(player, arg-1)
        set {_item2} to giveChestplate(player, arg-1)
        set {_item3} to giveLeggings(player, arg-1)
        set {_item4} to giveBoots(player, arg-1)
        give {_item1} to player
        give {_item2} to player
        give {_item3} to player
        give {_item4} to player