            set {_item} to chestplate(leather chestplate, "Cinder Chestplate", 8, 243, 77, 0)
        case 9:
            set {_item} to chestplate(leather chestplate, "Bone Chestplate", 9, 255, 255, 255)
        case 10:
            set {_item} to chestplate(leather chestplate, "Rusty Chestplate", 10, 145, 114, 85)
        case 11:
            set {_item} to chestplate(leather chestplate, "Timber Chestplate", 11, 121, 104, 91)
        case 12:
            set {_item} to chestplate(leather chestplate, "Frost Chestplate", 12, 64, 81, 90)
        case 13:
            set {_item} to chestplate(leather chestplate, "Blaze Chestplate", 13, 159, 59, 16)
        case 14:
            set {_item} to chestplate(leather chestplate, "Ender Chestplate", 14, 72, 72, 74)
        case 15:
            set {_item} to chestplate(leather chestplate, "Warden Chestplate", 15, 84, 72, 86)
        case 16:
            set {_item} to chestplate(leather chestplate, "Wither Chestplate", 16, 48, 47, 46)
        case 17:
